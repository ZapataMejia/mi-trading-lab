BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_here
BYBIT_API_KEY=your_api_key_here
BYBIT_SECRET=your_secret_here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# LIVE: reutiliza el bot de V1 (mismo token) o crea TELEGRAM_BOT_TOKEN_LIVE=
TELEGRAM_BOT_TOKEN_LIVE=
TELEGRAM_CHAT_ID_LIVE=
TELEGRAM_BOT_TOKEN_V2=your_second_bot_token_here
TELEGRAM_BOT_TOKEN_V4B=your_v4b_bot_token_here
# Mismo chat para DEMO+LIVE = comparacion lado a lado (opcional)
TELEGRAM_CHAT_ID_DEMO=
TELEGRAM_CHAT_ID_LIVE=-100xxxxxxxxxx
OPENAI_API_KEY=your_openai_key_here

# Polymarket LIVE (V4B) — never commit real values
# PRIVATE_KEY = exportar desde polymarket.com → Settings → Export Private Key
# FUNDER = dirección del perfil (avatar → copiar wallet), NO la misma que el EOA
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_FUNDER_ADDRESS=0x...
# 3 = cuenta Google nueva (Perfil → Dirección API)  |  1 = Magic proxy viejo  |  2 = Safe
POLYMARKET_SIGNATURE_TYPE=3
POLYMARKET_CHAIN_ID=137
# Slippage FOK LIVE; endgame fino suele necesitar 15-20 (Jun 2026: 10 fallaba mucho)
POLYMARKET_MAX_SLIPPAGE_CENTS=20
POLYMARKET_LIVE_ENABLED=true
